# Copy to .env and adjust as needed. Docker Compose reads this file
# automatically. All values here are safe local-dev defaults — change
# SECRET_KEY and the DB/RabbitMQ credentials before deploying anywhere
# real (see DEPLOYMENT.md).

# --- App ---
ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
LOG_JSON=true
LOG_LEVEL=INFO

# --- Postgres ---
POSTGRES_USER=cacheflow
POSTGRES_PASSWORD=cacheflow
POSTGRES_DB=cacheflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
URL_CACHE_TTL_SECONDS=3600

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=cacheflow
RABBITMQ_PASSWORD=cacheflow

# --- Rate limiting ---
RATE_LIMIT_CREATE_MAX=30
RATE_LIMIT_CREATE_WINDOW_SECONDS=60
RATE_LIMIT_REDIRECT_MAX=100
RATE_LIMIT_REDIRECT_WINDOW_SECONDS=60

# --- Short URL base (what gets returned in API responses) ---
# Points at the load balancer's exposed port; this is what users will
# actually click on.
SHORT_URL_BASE=http://13.49.57.61.nip.io:8080

# --- CORS (frontend origin) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://13.49.57.61.nip.io:3000

# --- Observability ---
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cacheflow-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Frontend build-time ---
# Leave blank to use the frontend nginx's same-origin /api proxy (default,
# recommended for docker-compose). Set to a full URL only if the frontend
# is served from a different origin than its API.
VITE_API_BASE_URL=

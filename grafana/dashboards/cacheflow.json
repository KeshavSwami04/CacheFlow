{
  "title": "CacheFlow — System Dashboard",
  "uid": "cacheflow-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["cacheflow"],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Request Rate",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "sum(rate(cacheflow_http_requests_total[1m]))", "legendFormat": "req/s", "refId": "A" }]
    },
    {
      "id": 2, "type": "stat", "title": "Cache Hit Rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.9 }] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "cacheflow_cache_hits_total / (cacheflow_cache_hits_total + cacheflow_cache_misses_total)", "legendFormat": "hit rate", "refId": "A" }]
    },
    {
      "id": 3, "type": "stat", "title": "Events Processed",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "cacheflow_events_processed", "legendFormat": "processed", "refId": "A" }]
    },
    {
      "id": 4, "type": "stat", "title": "Active Workers",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "cacheflow_active_workers", "legendFormat": "workers", "refId": "A" }]
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP Request Rate by Endpoint",
      "gridPos": { "x": 0, "y": 4, "w": 14, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 8 } }, "overrides": [] },
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "sum by (endpoint) (rate(cacheflow_http_requests_total[1m]))", "legendFormat": "{{endpoint}}", "refId": "A" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Response Time (p50 / p95 / p99)",
      "gridPos": { "x": 14, "y": 4, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum(rate(cacheflow_http_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(cacheflow_http_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "datasource": { "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(cacheflow_http_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Cache Hits vs Misses",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 12 } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Hits" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "Misses" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
      ] },
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "rate(cacheflow_cache_hits_total[1m])", "legendFormat": "Hits", "refId": "A" },
        { "datasource": { "uid": "prometheus" }, "expr": "rate(cacheflow_cache_misses_total[1m])", "legendFormat": "Misses", "refId": "B" }
      ]
    },
    {
      "id": 8, "type": "gauge", "title": "Cache Hit Ratio",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizWidth": 75, "minVizHeight": 75 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.9 }] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "cacheflow_cache_hits_total / (cacheflow_cache_hits_total + cacheflow_cache_misses_total)", "legendFormat": "", "refId": "A" }]
    },
    {
      "id": 9, "type": "timeseries", "title": "Error Rate (5xx)",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 20 }, "color": { "fixedColor": "red", "mode": "fixed" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "sum(rate(cacheflow_http_requests_total{status_code=~\"5..\"}[2m])) / sum(rate(cacheflow_http_requests_total[2m]))", "legendFormat": "error %", "refId": "A" }]
    },
    {
      "id": 10, "type": "timeseries", "title": "RabbitMQ Queue Depth",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [
        { "matcher": { "id": "byName", "options": "DLQ" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
      ] },
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "cacheflow_queue_depth", "legendFormat": "click_events.process", "refId": "A" },
        { "datasource": { "uid": "prometheus" }, "expr": "cacheflow_dlq_depth", "legendFormat": "DLQ", "refId": "B" }
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "URLs Created & Redirects Served",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 8 } }, "overrides": [] },
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "rate(cacheflow_redirects_total[1m])", "legendFormat": "Redirects/s", "refId": "A" },
        { "datasource": { "uid": "prometheus" }, "expr": "rate(cacheflow_urls_created_total[1m])", "legendFormat": "URLs created/s", "refId": "B" }
      ]
    },
    {
      "id": 12, "type": "timeseries", "title": "Redis Memory Usage",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "legend": { "displayMode": "hidden" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "color": { "fixedColor": "orange", "mode": "fixed" } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "redis_memory_used_bytes", "legendFormat": "used", "refId": "A" }]
    },
    {
      "id": 13, "type": "timeseries", "title": "Redis Commands / sec",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "legend": { "displayMode": "hidden" } },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 8 }, "color": { "fixedColor": "purple", "mode": "fixed" } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "rate(redis_commands_processed_total[1m])", "legendFormat": "cmd/s", "refId": "A" }]
    },
    {
      "id": 14, "type": "stat", "title": "Redis Connected Clients",
      "gridPos": { "x": 16, "y": 28, "w": 4, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "redis_connected_clients", "legendFormat": "clients", "refId": "A" }]
    },
    {
      "id": 15, "type": "stat", "title": "DB Pool Connections In Use",
      "gridPos": { "x": 20, "y": 28, "w": 4, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 18 }] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "cacheflow_db_pool_connections_checked_out", "legendFormat": "checked out", "refId": "A" }]
    }
  ]
}
